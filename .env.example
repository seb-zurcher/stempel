# Google OAuth 2.0 Client ID for Google Drive sync
#
# Setup:
# 1. https://console.cloud.google.com → New project
# 2. APIs & Services → Enable "Google Drive API"
# 3. OAuth consent screen → External → add scope: .../auth/drive.appdata
# 4. Credentials → Create OAuth 2.0 Client ID (Web application)
# 5. Authorized redirect URIs:
#      http://localhost:5173/          ← local dev
#      https://your-github-pages-url/ ← production
# 6. Paste the Client ID below

VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Required for Google "Web application" OAuth clients (token exchange)
# Find it alongside the Client ID in Google Cloud Console → Credentials
VITE_GOOGLE_CLIENT_SECRET=your-client-secret
